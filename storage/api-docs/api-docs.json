{
    "openapi": "3.0.0",
    "info": {
        "title": "IBC API",
        "description": "REST API modul UMKM & customer untuk aplikasi mobile",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Server lokal"
        }
    ],
    "paths": {
        "/api/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Registrasi customer baru",
                "operationId": "8e4e3cb7b46126f4696379d3c7eeb4ad",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "password_confirmation": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Terdaftar, kembalikan token"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login, kembalikan bearer token",
                "operationId": "222b2625838e3c57e017987f73598fda",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Token + user"
                    },
                    "422": {
                        "description": "Kredensial salah / akun nonaktif"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Hapus token aktif",
                "operationId": "ad65cbbd4e9f201619eae184a5961a98",
                "responses": {
                    "200": {
                        "description": "Token dihapus"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/checkout/{umkm}": {
            "get": {
                "tags": [
                    "Checkout"
                ],
                "summary": "Ringkasan checkout per toko (item, total, rekening)",
                "operationId": "d8cc20eb469d8b2f25678228691118ee",
                "parameters": [
                    {
                        "name": "umkm",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ringkasan"
                    },
                    "422": {
                        "description": "Tidak ada item untuk toko ini"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Checkout"
                ],
                "summary": "Buat pesanan dari keranjang toko ini",
                "operationId": "216cfa27a14f4aae07d888027a31ea56",
                "parameters": [
                    {
                        "name": "umkm",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "bank_id"
                                ],
                                "properties": {
                                    "bank_id": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Transaksi dibuat"
                    },
                    "422": {
                        "description": "Keranjang kosong / bank salah / stok kurang"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/keranjang": {
            "get": {
                "tags": [
                    "Keranjang"
                ],
                "summary": "Isi keranjang user",
                "operationId": "7711192db8820e0c3687c3668d345a3c",
                "responses": {
                    "200": {
                        "description": "Daftar item + produk + toko"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/keranjang/{produk}": {
            "post": {
                "tags": [
                    "Keranjang"
                ],
                "summary": "Tambah produk ke keranjang",
                "operationId": "e712c143adaad39562bd09004d5866e8",
                "parameters": [
                    {
                        "name": "produk",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "qty": {
                                        "type": "integer",
                                        "default": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Item keranjang"
                    },
                    "422": {
                        "description": "Produk tidak tersedia"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/keranjang/{keranjang}": {
            "delete": {
                "tags": [
                    "Keranjang"
                ],
                "summary": "Hapus item",
                "operationId": "7f3fb8da4d1d8bf9c326152055b9d40a",
                "parameters": [
                    {
                        "name": "keranjang",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Terhapus"
                    },
                    "404": {
                        "description": "Bukan milik user"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "patch": {
                "tags": [
                    "Keranjang"
                ],
                "summary": "Ubah qty (action increase/decrease atau qty langsung)",
                "operationId": "026882ec8e27301b2ec27b8b7459210d",
                "parameters": [
                    {
                        "name": "keranjang",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "action": {
                                        "type": "string",
                                        "enum": [
                                            "increase",
                                            "decrease"
                                        ]
                                    },
                                    "qty": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Item ter-update"
                    },
                    "404": {
                        "description": "Bukan milik user"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/produk": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Daftar produk tampil (show=true)",
                "operationId": "3c74aa47134424450a7cf8e1942a2172",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "umkm",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "kategori",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginasi produk"
                    }
                }
            }
        },
        "/api/produk/{produk}": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Detail produk + toko + atribut",
                "operationId": "a28ad28f3ba3a9a81c73d547772c961f",
                "parameters": [
                    {
                        "name": "produk",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail produk"
                    },
                    "404": {
                        "description": "Tidak ada"
                    }
                }
            }
        },
        "/api/profile": {
            "get": {
                "tags": [
                    "Profil"
                ],
                "summary": "Profil user login",
                "operationId": "f1784685f8270527da017b3616288443",
                "responses": {
                    "200": {
                        "description": "Data user"
                    },
                    "401": {
                        "description": "Belum login"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "patch": {
                "tags": [
                    "Profil"
                ],
                "summary": "Ubah profil",
                "operationId": "9b7235bb283355b576750777fbc0a703",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profil diperbarui"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/toko": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Daftar toko UMKM aktif",
                "operationId": "8a61d18e248986dc80cba6c9a4819ab1",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginasi toko"
                    }
                }
            }
        },
        "/api/toko/{umkm}": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Detail toko + info jenis usaha",
                "operationId": "a7f2044bcbc7e1a196489040597bab1b",
                "parameters": [
                    {
                        "name": "umkm",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail toko"
                    },
                    "404": {
                        "description": "Tidak ada / nonaktif"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Checkout",
            "description": "Checkout"
        },
        {
            "name": "Keranjang",
            "description": "Keranjang"
        },
        {
            "name": "Publik",
            "description": "Publik"
        },
        {
            "name": "Profil",
            "description": "Profil"
        }
    ]
}