{
    "openapi": "3.0.0",
    "info": {
        "title": "IBC API",
        "description": "REST API modul UMKM & customer untuk aplikasi mobile",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Server lokal"
        }
    ],
    "paths": {
        "/api/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Registrasi customer baru",
                "operationId": "8e4e3cb7b46126f4696379d3c7eeb4ad",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "password_confirmation": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Terdaftar, kembalikan token"
                    },
                    "422": {
                        "description": "Validasi gagal"
                    }
                }
            }
        },
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Login, kembalikan bearer token",
                "operationId": "222b2625838e3c57e017987f73598fda",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Token + user"
                    },
                    "422": {
                        "description": "Kredensial salah / akun nonaktif"
                    }
                }
            }
        },
        "/api/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Hapus token aktif",
                "operationId": "ad65cbbd4e9f201619eae184a5961a98",
                "responses": {
                    "200": {
                        "description": "Token dihapus"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/produk": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Daftar produk tampil (show=true)",
                "operationId": "3c74aa47134424450a7cf8e1942a2172",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "umkm",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "kategori",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginasi produk"
                    }
                }
            }
        },
        "/api/produk/{produk}": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Detail produk + toko + atribut",
                "operationId": "a28ad28f3ba3a9a81c73d547772c961f",
                "parameters": [
                    {
                        "name": "produk",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail produk"
                    },
                    "404": {
                        "description": "Tidak ada"
                    }
                }
            }
        },
        "/api/profile": {
            "get": {
                "tags": [
                    "Profil"
                ],
                "summary": "Profil user login",
                "operationId": "f1784685f8270527da017b3616288443",
                "responses": {
                    "200": {
                        "description": "Data user"
                    },
                    "401": {
                        "description": "Belum login"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "patch": {
                "tags": [
                    "Profil"
                ],
                "summary": "Ubah profil",
                "operationId": "9b7235bb283355b576750777fbc0a703",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "phone": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profil diperbarui"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/toko": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Daftar toko UMKM aktif",
                "operationId": "8a61d18e248986dc80cba6c9a4819ab1",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginasi toko"
                    }
                }
            }
        },
        "/api/toko/{umkm}": {
            "get": {
                "tags": [
                    "Publik"
                ],
                "summary": "Detail toko + info jenis usaha",
                "operationId": "a7f2044bcbc7e1a196489040597bab1b",
                "parameters": [
                    {
                        "name": "umkm",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Detail toko"
                    },
                    "404": {
                        "description": "Tidak ada / nonaktif"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Publik",
            "description": "Publik"
        },
        {
            "name": "Profil",
            "description": "Profil"
        }
    ]
}